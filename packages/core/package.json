    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "postinstall": "node scripts/fix-spawn-helper.mjs",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "zod": "^4.0.0"
  }
}
