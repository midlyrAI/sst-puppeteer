{
  "name": "@sst-puppeteer/core",
  "version": "0.0.0",
  "description": "Core for sst-puppeteer — SSTSession, /stream subscription, pane navigation, default node-pty adapter.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
