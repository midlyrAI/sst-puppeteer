{
  "name": "@sst-puppeteer/cli",
  "version": "0.1.0",
  "description": "CLI for sst-puppeteer — utility commands. The MCP server ships separately as @sst-puppeteer/mcp.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "sst-puppeteer": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@sst-puppeteer/core": "workspace:*"
  }
}
