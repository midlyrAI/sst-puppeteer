{
  "name": "sst-puppeteer-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Headless control layer for sst dev — toolkit (MCP server, CLI, SDK) for driving SST programmatically.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "echo \"no dev mode in v0.1 skeleton\"",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:types": "pnpm -r exec tsc --noEmit",
    "clean": "pnpm -r exec rm -rf dist *.tsbuildinfo",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "eslint": "^9.13.0",
    "expect-type": "^1.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.3"
  }
}
