{
  "name": "@midlyr/sst-puppeteer-mcp",
  "version": "0.1.1",
  "type": "module",
  "description": "MCP server for driving sst dev — gives AI agents the full interactive-TUI feature set (per-pane restart, stream events, log tail, redeploy waits) plus a passthrough for one-shot SST subcommands.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/midlyrAI/sst-puppeteer.git"
  },
  "bugs": {
    "url": "https://github.com/midlyrAI/sst-puppeteer/issues"
  },
  "homepage": "https://github.com/midlyrAI/sst-puppeteer#readme",
  "keywords": [
    "sst",
    "mcp",
    "model-context-protocol",
    "claude",
    "ai-agents",
    "serverless"
  ],
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "sst-puppeteer-mcp": "./dist/bin/mcp.js",
    "sst-puppeteer": "./dist/bin/cli.js"
  },
  "files": [
    "dist",
    "scripts/fix-spawn-helper.mjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/bin/*.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint bin src test",
    "lint:fix": "eslint bin src test --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "postinstall": "node scripts/fix-spawn-helper.mjs",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "node-pty": "^1.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "eslint": "^9.13.0",
    "expect-type": "^1.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.3"
  },
  "packageManager": "pnpm@9.12.0"
}
